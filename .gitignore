# Local .terraform directories (contains provider binaries and modules)
**/.terraform/*


**/node_modules/*

# .tfstate files (contains sensitive infrastructure data)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files (likely contains secrets/passwords)
*.tfvars
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore transient lock info files
.terraform.tfstate.lock.info

# Include tfplan files if you use 'terraform plan -out=tfplan'
*tfplan*

# Terraform CLI configuration files
.terraformrc
terraform.rc

